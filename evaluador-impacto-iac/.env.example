# Copia este archivo como .env para desarrollo local
# La key se usa SOLO en el servidor (proxy Vite / función Vercel), nunca en el bundle del cliente.

MISTRAL_API_KEY=tu_api_key_aqui

# Alternativa compatible (mismo uso server-side en dev):
# VITE_MISTRAL_API_KEY=tu_api_key_aqui

# Supabase — portafolio de escenarios (cliente; prefijo VITE_ requerido)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
